{
  "version": 8,
  "name": "Trails Overlay",
  "sources": {
    "osm": {
      "type": "vector",
      "url": "http://localhost:3000/osm"
    }
  },
  "layers": [
    {
      "id": "highway-path-casing",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": [
        "in", ["get", "highway"],
        ["literal", ["footway", "path", "track", "bridleway", "cycleway", "steps", "via_ferrata"]]
      ],
      "minzoom": 11,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          11, ["match", ["get", "highway"],
            ["track", "bridleway"], 4,
            ["footway", "path", "steps"], 3,
            2
          ],
          16, ["match", ["get", "highway"],
            ["track", "bridleway"], 8,
            ["footway", "path", "steps"], 6,
            4
          ]
        ],
        "line-opacity": 0.6
      }
    },
    {
      "id": "highway-track",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": ["==", ["get", "highway"], "track"],
      "minzoom": 11,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": [
          "match", ["coalesce", ["get", "tracktype", ["get", "tags"]], ""],
          "grade1", "#b87333",
          "grade2", "#c8944a",
          "grade3", "#d8a860",
          "#c09050"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 1.5, 16, 4],
        "line-dasharray": [
          "step", ["zoom"],
          ["literal", [3, 2]], 13,
          ["literal", [1, 0]]
        ]
      }
    },
    {
      "id": "highway-bridleway",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": ["==", ["get", "highway"], "bridleway"],
      "minzoom": 11,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#4caf50",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 1.5, 16, 4]
      }
    },
    {
      "id": "highway-cycleway",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": ["==", ["get", "highway"], "cycleway"],
      "minzoom": 11,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#2196f3",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 1.5, 16, 3.5]
      }
    },
    {
      "id": "highway-footway",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": [
        "in", ["get", "highway"], ["literal", ["footway", "pedestrian", "corridor"]]
      ],
      "minzoom": 12,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#ff7043",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1, 16, 3]
      }
    },
    {
      "id": "highway-path",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": ["==", ["get", "highway"], "path"],
      "minzoom": 11,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": [
          "match",
          ["coalesce", ["get", "designation", ["get", "tags"]], ""],
          ["public_footpath", "permissive_footpath"], "#ff7043",
          ["public_bridleway", "permissive_bridleway"], "#4caf50",
          ["byway_open_to_all_traffic", "restricted_byway"], "#9c6020",
          "#e64a19"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 1, 16, 3],
        "line-dasharray": [
          "step", ["zoom"],
          ["literal", [4, 2]], 14,
          ["literal", [1, 0]]
        ]
      }
    },
    {
      "id": "highway-steps",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": ["==", ["get", "highway"], "steps"],
      "minzoom": 13,
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "#ff7043",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 2, 17, 5],
        "line-dasharray": [0.5, 0.5]
      }
    },
    {
      "id": "highway-via-ferrata",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": ["==", ["get", "highway"], "via_ferrata"],
      "minzoom": 11,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#d32f2f",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 1.5, 16, 3.5],
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "route-iwn-nwn",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": [
        "in", ["get", "primary_route_network"], ["literal", ["iwn", "nwn"]]
      ],
      "minzoom": 7,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": [
          "case",
          ["!=", ["coalesce", ["get", "primary_route_color"], ""], ""],
          ["get", "primary_route_color"],
          "#e91e63"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 2, 14, 5],
        "line-opacity": 0.85,
        "line-offset": 3
      }
    },
    {
      "id": "route-rwn",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": ["==", ["get", "primary_route_network"], "rwn"],
      "minzoom": 9,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": [
          "case",
          ["!=", ["coalesce", ["get", "primary_route_color"], ""], ""],
          ["get", "primary_route_color"],
          "#9c27b0"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 1.5, 14, 4],
        "line-opacity": 0.8,
        "line-offset": 2
      }
    },
    {
      "id": "route-lwn",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": ["==", ["get", "primary_route_network"], "lwn"],
      "minzoom": 11,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": [
          "case",
          ["!=", ["coalesce", ["get", "primary_route_color"], ""], ""],
          ["get", "primary_route_color"],
          "#ff9800"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 1, 14, 3],
        "line-opacity": 0.75,
        "line-offset": 1.5
      }
    },
    {
      "id": "route-ncn",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": [
        "in", ["get", "primary_route_network"], ["literal", ["icn", "ncn"]]
      ],
      "minzoom": 8,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#0288d1",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1.5, 14, 4],
        "line-opacity": 0.8,
        "line-offset": 3
      }
    },
    {
      "id": "route-rcn-lcn",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": [
        "in", ["get", "primary_route_network"], ["literal", ["rcn", "lcn"]]
      ],
      "minzoom": 11,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#4fc3f7",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 1, 14, 3],
        "line-opacity": 0.75,
        "line-offset": 1.5
      }
    },
    {
      "id": "route-ref-label",
      "type": "symbol",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": [
        "all",
        ["!=", ["coalesce", ["get", "primary_route_ref"], ""], ""],
        [
          "in", ["get", "primary_route_network"],
          ["literal", ["iwn", "nwn", "rwn", "lwn", "icn", "ncn", "rcn", "lcn"]]
        ]
      ],
      "minzoom": 10,
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": 300,
        "text-field": ["get", "primary_route_ref"],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 9, 16, 13],
        "text-max-angle": 30
      },
      "paint": {
        "text-color": "#ffffff",
        "text-halo-color": [
          "match", ["get", "primary_route_network"],
          ["iwn", "nwn"], "#e91e63",
          "rwn", "#9c27b0",
          "lwn", "#ff9800",
          ["icn", "ncn"], "#0288d1",
          ["rcn", "lcn"], "#4fc3f7",
          "#555555"
        ],
        "text-halo-width": 2
      }
    },
    {
      "id": "highway-path-label",
      "type": "symbol",
      "source": "osm",
      "source-layer": "osm_lines",
      "filter": [
        "all",
        ["!=", ["coalesce", ["get", "name"], ""], ""],
        [
          "in", ["get", "highway"],
          ["literal", ["footway", "path", "track", "bridleway", "cycleway", "steps"]]
        ]
      ],
      "minzoom": 13,
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": 250,
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 9, 17, 13],
        "text-max-angle": 30,
        "text-offset": [0, -1]
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "poi-gate-stile",
      "type": "symbol",
      "source": "osm",
      "source-layer": "osm_points",
      "filter": [
        "in",
        ["coalesce", ["get", "barrier", ["get", "tags"]], ""],
        ["literal", ["gate", "stile", "kissing_gate", "turnstile", "lift_gate"]]
      ],
      "minzoom": 15,
      "layout": {
        "icon-image": [
          "match",
          ["coalesce", ["get", "barrier", ["get", "tags"]], ""],
          ["stile", "turnstile"], "cross-11",
          "gate-11"
        ],
        "icon-size": 0.8,
        "icon-allow-overlap": false
      },
      "paint": {}
    }
  ]
}
