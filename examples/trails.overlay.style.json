{
  "version": 8,
  "name": "Trails Overlay",
  "metadata": {},
  "sources": {
    "osm": {
      "type": "vector",
      "url": "http://localhost:3000/trails_overlay"
    },
    "demo-osm-raster": {
      "type": "raster",
      "tiles": [
        "https://tile.openstreetmap.org/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "attribution": "© OpenStreetMap contributors"
    },
    "demo-os-leisure": {
      "type": "raster",
      "url": "https://tile.plantopo.com/os-leisure"
    },
    "demo-os-outdoor": {
      "type": "raster",
      "tiles": [
        "https://tile.plantopo.com/os-outdoor/{z}/{x}/{y}"
      ],
      "tileSize": 256,
      "minzoom": 7,
      "maxzoom": 20,
      "bounds": [
        -9.24941,
        49.85961,
        2.781412,
        60.907668
      ],
      "attribution": "<a href=\"https://www.ordnancesurvey.co.uk/governance/crown-copyright\">Contains OS data &copy; Crown copyright and database rights YEAR</a>"
    },
    "demo-satellite": {
      "type": "raster",
      "tiles": [
        "https://mt1.google.com/vt/lyrs=s&x={x}&y={y}&z={z}",
        "https://mt2.google.com/vt/lyrs=s&x={x}&y={y}&z={z}",
        "https://mt3.google.com/vt/lyrs=s&x={x}&y={y}&z={z}"
      ],
      "tileSize": 256,
      "minzoom": 0,
      "maxzoom": 21,
      "attribution": "Map data &copy; Google YEAR"
    }
  },
  "sprite": "https://tile.plantopo.com/sprite/sprite",
  "layers": [
    {
      "id": "demo-backdrop-osm",
      "type": "raster",
      "source": "demo-osm-raster"
    },
    {
      "id": "demo-backdrop-os-leisure",
      "type": "raster",
      "source": "demo-os-leisure",
      "minzoom": 13,
      "maxzoom": 15
    },
    {
      "id": "demo-backdrop-os-detail",
      "type": "raster",
      "source": "demo-os-outdoor",
      "minzoom": 16,
      "layout": {
        "visibility": "none"
      }
    },
    {
      "id": "demo-backdrop-satellite",
      "type": "raster",
      "source": "demo-satellite",
      "layout": {
        "visibility": "none"
      }
    },
    {
      "id": "highway-path-casing",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "minzoom": 10,
      "filter": [
        "all",
        [
          "in",
          [
            "get",
            "highway"
          ],
          [
            "literal",
            [
              "footway",
              "path",
              "track",
              "bridleway",
              "cycleway",
              "steps",
              "via_ferrata"
            ]
          ]
        ],
        [
          "match",
          [
            "coalesce",
            [
              "get",
              "footway"
            ],
            ""
          ],
          [
            "sidewalk",
            "crossing",
            "access_aisle",
            "traffic_island",
            "link"
          ],
          false,
          true
        ]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          [
            "match",
            [
              "get",
              "highway"
            ],
            [
              "track",
              "bridleway"
            ],
            4,
            [
              "footway",
              "path",
              "steps"
            ],
            3,
            2
          ],
          16,
          [
            "match",
            [
              "get",
              "highway"
            ],
            [
              "track",
              "bridleway"
            ],
            8,
            [
              "footway",
              "path",
              "steps"
            ],
            6,
            4
          ]
        ],
        "line-opacity": 0.6
      }
    },
    {
      "id": "highway-track",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "minzoom": 10,
      "filter": [
        "==",
        [
          "get",
          "highway"
        ],
        "track"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": [
          "match",
          [
            "coalesce",
            [
              "get",
              "tracktype"
            ],
            ""
          ],
          "grade1",
          "#b87333",
          "grade2",
          "#c8944a",
          "grade3",
          "#d8a860",
          "#c09050"
        ],
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          1.5,
          16,
          4
        ],
        "line-dasharray": [
          3,
          2
        ]
      }
    },
    {
      "id": "highway-bridleway",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "minzoom": 10,
      "filter": [
        "==",
        [
          "get",
          "highway"
        ],
        "bridleway"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#4caf50",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          1.5,
          16,
          4
        ]
      }
    },
    {
      "id": "highway-cycleway",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "minzoom": 10,
      "filter": [
        "==",
        [
          "get",
          "highway"
        ],
        "cycleway"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#2196f3",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          1.5,
          16,
          3.5
        ]
      }
    },
    {
      "id": "highway-footway",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "minzoom": 10,
      "filter": [
        "all",
        [
          "in",
          [
            "get",
            "highway"
          ],
          [
            "literal",
            [
              "footway",
              "pedestrian",
              "corridor"
            ]
          ]
        ],
        [
          "match",
          [
            "coalesce",
            [
              "get",
              "footway"
            ],
            ""
          ],
          [
            "sidewalk",
            "crossing",
            "access_aisle",
            "traffic_island",
            "link"
          ],
          false,
          true
        ]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#81c784",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          1,
          16,
          3
        ]
      }
    },
    {
      "id": "highway-path",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "minzoom": 10,
      "filter": [
        "==",
        [
          "get",
          "highway"
        ],
        "path"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": [
          "match",
          [
            "coalesce",
            [
              "get",
              "sac_scale"
            ],
            ""
          ],
          "hiking",
          "#66bb6a",
          "mountain_hiking",
          "#ffca28",
          "demanding_mountain_hiking",
          "#ffa726",
          "alpine_hiking",
          "#ef5350",
          "demanding_alpine_hiking",
          "#b71c1c",
          "difficult_alpine_hiking",
          "#6a1a6a",
          "#e64a19"
        ],
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          1,
          16,
          3
        ],
        "line-dasharray": [
          4,
          2
        ]
      }
    },
    {
      "id": "designation-overlay",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "minzoom": 10,
      "filter": [
        "in",
        [
          "coalesce",
          [
            "get",
            "designation"
          ],
          ""
        ],
        [
          "literal",
          [
            "public_footpath",
            "permissive_footpath",
            "public_bridleway",
            "permissive_bridleway",
            "byway_open_to_all_traffic",
            "restricted_byway"
          ]
        ]
      ],
      "layout": {
        "line-cap": "butt",
        "line-join": "round"
      },
      "paint": {
        "line-color": [
          "match",
          [
            "coalesce",
            [
              "get",
              "designation"
            ],
            ""
          ],
          [
            "public_bridleway",
            "permissive_bridleway"
          ],
          "#1b5e20",
          [
            "byway_open_to_all_traffic",
            "restricted_byway"
          ],
          "#4e342e",
          "#2e7d32"
        ],
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          2,
          16,
          5
        ],
        "line-dasharray": [
          3,
          3
        ],
        "line-opacity": 0.8
      }
    },
    {
      "id": "sac-scale-label",
      "type": "symbol",
      "source": "osm",
      "source-layer": "osm_lines",
      "minzoom": 13,
      "filter": [
        "all",
        [
          "==",
          [
            "get",
            "highway"
          ],
          "path"
        ],
        [
          "in",
          [
            "coalesce",
            [
              "get",
              "sac_scale"
            ],
            ""
          ],
          [
            "literal",
            [
              "hiking",
              "mountain_hiking",
              "demanding_mountain_hiking",
              "alpine_hiking",
              "demanding_alpine_hiking",
              "difficult_alpine_hiking"
            ]
          ]
        ]
      ],
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": 200,
        "text-field": [
          "match",
          [
            "coalesce",
            [
              "get",
              "sac_scale"
            ],
            ""
          ],
          "hiking",
          "T1",
          "mountain_hiking",
          "T2",
          "demanding_mountain_hiking",
          "T3",
          "alpine_hiking",
          "T4",
          "demanding_alpine_hiking",
          "T5",
          "difficult_alpine_hiking",
          "T6",
          ""
        ],
        "text-font": [
          "Overpass Bold"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          13,
          9,
          17,
          12
        ],
        "text-max-angle": 30,
        "text-offset": [
          0,
          -1
        ]
      },
      "paint": {
        "text-color": [
          "match",
          [
            "coalesce",
            [
              "get",
              "sac_scale"
            ],
            ""
          ],
          "hiking",
          "#66bb6a",
          "mountain_hiking",
          "#ffca28",
          "demanding_mountain_hiking",
          "#ffa726",
          "alpine_hiking",
          "#ef5350",
          "demanding_alpine_hiking",
          "#b71c1c",
          "difficult_alpine_hiking",
          "#6a1a6a",
          "#e64a19"
        ],
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "highway-steps",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "minzoom": 13,
      "filter": [
        "==",
        [
          "get",
          "highway"
        ],
        "steps"
      ],
      "layout": {
        "line-cap": "butt",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ff7043",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          13,
          2,
          17,
          5
        ],
        "line-dasharray": [
          0.5,
          0.5
        ]
      }
    },
    {
      "id": "highway-via-ferrata",
      "type": "line",
      "source": "osm",
      "source-layer": "osm_lines",
      "minzoom": 10,
      "filter": [
        "==",
        [
          "get",
          "highway"
        ],
        "via_ferrata"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d32f2f",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          1.5,
          16,
          3.5
        ],
        "line-dasharray": [
          2,
          2
        ]
      }
    },
    {
      "id": "route-ref-label",
      "type": "symbol",
      "source": "osm",
      "source-layer": "osm_lines",
      "minzoom": 10,
      "filter": [
        "in",
        [
          "get",
          "primary_route_network"
        ],
        [
          "literal",
          [
            "iwn",
            "nwn",
            "rwn",
            "lwn",
            "icn",
            "ncn",
            "rcn",
            "lcn"
          ]
        ]
      ],
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": 300,
        "text-field": [
          "coalesce",
          [
            "get",
            "primary_route_ref"
          ],
          [
            "get",
            "primary_route_name"
          ],
          [
            "match",
            [
              "get",
              "primary_route_network"
            ],
            "iwn",
            "IWN",
            "nwn",
            "NWN",
            "rwn",
            "RWN",
            "lwn",
            "LWN",
            "icn",
            "ICN",
            "ncn",
            "NCN",
            "rcn",
            "RCN",
            "lcn",
            "LCN",
            ""
          ]
        ],
        "text-font": [
          "Overpass Bold"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          9,
          16,
          13
        ],
        "text-max-angle": 30,
        "text-offset": [
          0,
          -1
        ]
      },
      "paint": {
        "text-color": [
          "case",
          [
            "!=",
            [
              "coalesce",
              [
                "get",
                "primary_route_color"
              ],
              ""
            ],
            ""
          ],
          [
            "get",
            "primary_route_color"
          ],
          [
            "match",
            [
              "get",
              "primary_route_network"
            ],
            [
              "iwn",
              "nwn"
            ],
            "#e91e63",
            "rwn",
            "#9c27b0",
            "lwn",
            "#ff9800",
            [
              "icn",
              "ncn"
            ],
            "#0288d1",
            [
              "rcn",
              "lcn"
            ],
            "#4fc3f7",
            "#555555"
          ]
        ],
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 2
      }
    },
    {
      "id": "highway-path-label",
      "type": "symbol",
      "source": "osm",
      "source-layer": "osm_lines",
      "minzoom": 13,
      "filter": [
        "all",
        [
          "!=",
          [
            "coalesce",
            [
              "get",
              "name"
            ],
            ""
          ],
          ""
        ],
        [
          "in",
          [
            "get",
            "highway"
          ],
          [
            "literal",
            [
              "footway",
              "path",
              "track",
              "bridleway",
              "cycleway",
              "steps"
            ]
          ]
        ]
      ],
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": 250,
        "text-field": [
          "get",
          "name"
        ],
        "text-font": [
          "Overpass Italic"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          13,
          9,
          17,
          13
        ],
        "text-max-angle": 30,
        "text-offset": [
          0,
          -1
        ]
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "poi-gate-stile",
      "type": "symbol",
      "source": "osm",
      "source-layer": "osm_points",
      "minzoom": 15,
      "filter": [
        "in",
        [
          "coalesce",
          [
            "get",
            "barrier"
          ],
          ""
        ],
        [
          "literal",
          [
            "gate",
            "stile",
            "kissing_gate",
            "turnstile",
            "lift_gate"
          ]
        ]
      ],
      "layout": {
        "icon-image": [
          "match",
          [
            "coalesce",
            [
              "get",
              "barrier"
            ],
            ""
          ],
          [
            "stile",
            "turnstile"
          ],
          "barrier/stile",
          "barrier/gate"
        ],
        "icon-size": 0.8,
        "icon-allow-overlap": false
      },
      "paint": {}
    }
  ],
  "id": "trails.overlay"
}